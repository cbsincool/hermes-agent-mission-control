# Hermes Mission Control - Docker 环境变量
# 复制此文件为 .env 并填入实际值

# 数据库配置
DATABASE_URL=postgresql://postgres:hermes2024@postgres:5432/hermes

# API 密钥（用于 Agent 心跳认证）
# 生成方法：openssl rand -hex 32
INTERNAL_API_SECRET=hermes-mission-control-secret-key-2024

# Postgres 配置
POSTGRES_USER=postgres
POSTGRES_PASSWORD=hermes2024
POSTGRES_DB=hermes
